# HubSpot — https://app.hubspot.com/api-keys
HUBSPOT_API_KEY=your_hubspot_private_app_token

# Google Calendar — https://console.cloud.google.com/apis/credentials
GOOGLE_CALENDAR_API_KEY=your_google_api_key
GOOGLE_CALENDAR_ID=primary   # or a specific calendar ID

# Swytchcode — run `swytchcode whoami` to get your token
SWYTCHCODE_TOKEN=your_swytchcode_token
